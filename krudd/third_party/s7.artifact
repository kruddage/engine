# SPDX-License-Identifier: GPL-2.0-or-later
#
# Config for the s7 artifacts, sourced by krudd/third_party/sync.sh. This is
# the one place the s7 fetch config lives — see VENDOR.md for the fetch
# mechanism and license rationale.
#
# s7 is no longer vendored as source here. kruddage/s7 re-cuts upstream S7 Scheme
# as this org's own GitHub Releases and ships prebuilt, linkable artifacts:
#
#   s7.h                       the public header (consumers #include "s7.h")
#   libs7-linux-x86_64.a       native static library (linux x86_64)
#   libs7-windows-x86_64.a     native static library (windows x86_64, MinGW-w64)
#   libs7-wasm32.a             wasm static library (built with emcc/emar)
#   krudds7-linux-x86_64       standalone s7 CLI (the kruddmake bootstrap interpreter)
#   krudds7-windows-x86_64.exe standalone s7 CLI, windows build
#
# The wasm-only KRUDD-LOCAL PATCH that used to live in this repo's s7.c now lives
# in kruddage/s7 and is baked into libs7-wasm32.a, so a new kruddage/s7 release
# is picked up with no source to re-patch here.
#
# We always build against the *latest* kruddage/s7 release rather than a pinned
# tag: S7_BASE_URL points at GitHub's "latest release" alias, which redirects to
# whichever release is newest at fetch time. sync.sh still verifies every asset
# against the ".sha256" sidecar published beside it in that release, so a
# corrupted or truncated download fails loudly even though the tag floats.
# There is nothing to bump here when kruddage/s7 cuts a new release — just
# delete the cached artifacts in this directory (libs7-*.a, s7.h,
# krudds7-linux-x86_64, krudds7-windows-x86_64.exe) and re-run sync.sh (or
# krudd.sh) to force a re-fetch; sync.sh's own sidecar-checksum comparison
# already refetches automatically once the cached artifact no longer matches
# the latest release's sidecar. S7_VERSION/S7_DATE are kept as upstream
# provenance and may lag the actual latest release.

S7_VERSION="10.8"
S7_DATE="17-Apr-2024"

S7_BASE_URL="https://github.com/kruddage/s7/releases/latest/download"

# Asset filenames within that release. Each is fetched together with its
# "<asset>.sha256" sidecar for integrity verification.
#
# s7.h and the wasm library are target-independent and shared by every host.
# The native library and CLI are host-specific; S7_NATIVE_LIB_ASSET and
# S7_CLI_ASSET below are the Linux pair (the default, used whenever sync.sh
# doesn't detect a Windows host). S7_*_ASSET_WINDOWS are the MinGW-w64 pair
# sync.sh switches to on a MINGW*/MSYS* uname.
S7_HEADER_ASSET="s7.h"
S7_WASM_LIB_ASSET="libs7-wasm32.a"

S7_NATIVE_LIB_ASSET="libs7-linux-x86_64.a"
S7_CLI_ASSET="krudds7-linux-x86_64"

S7_NATIVE_LIB_ASSET_WINDOWS="libs7-windows-x86_64.a"
S7_CLI_ASSET_WINDOWS="krudds7-windows-x86_64.exe"
