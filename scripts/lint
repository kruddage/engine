#!/bin/sh
# SPDX-License-Identifier: GPL-2.0-or-later
#
# Single entry point for the repo's source-lint checks. The same command runs
# locally and in CI, so "does my change pass the greps?" is one command, not a
# hunt through .github/workflows/ci.yml.
#
# Usage: scripts/lint [CHECK] [ARGS...]
#
#   scripts/lint                run every source check (em-asm, raw-malloc), and
#                               the symbol-resolution check too if ./build exists
#   scripts/lint em-asm         ban EM_ASM_* in plugin sources
#   scripts/lint raw-malloc     ban raw malloc/free/realloc/calloc outside memory
#   scripts/lint symbols [DIR]  plugin symbol resolution over a build (DIR=build)
#   scripts/lint imports [DIR]  plugin banned-import check over a build (DIR=build)
#
# The source checks (em-asm, raw-malloc) need no toolchain. The build checks
# (symbols, imports) need a completed build tree; `imports` additionally needs
# wasm-objdump (WABT) and is skipped with a notice when it is absent. `imports`
# is not part of the default run: whether that rule is enforced in CI is still
# open (see issue #304), so this entry point exposes it without turning it on.

set -e

HERE=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)

lint_em_asm() {
	sh "$HERE/check-plugin-no-em-asm.sh" plugins
}

lint_raw_malloc() {
	sh "$HERE/check-no-raw-malloc.sh" modules plugins
}

lint_symbols() {
	dir="${1:-build}"
	if [ ! -d "$dir" ]; then
		printf "FAIL: %s is not a build directory (build first)\n" "$dir" >&2
		return 2
	fi
	node "$HERE/check-plugin-symbols.mjs" "$dir"
}

lint_imports() {
	dir="${1:-build}"
	if [ ! -d "$dir" ]; then
		printf "FAIL: %s is not a build directory (build first)\n" "$dir" >&2
		return 2
	fi
	if ! command -v wasm-objdump >/dev/null 2>&1; then
		printf "SKIP: wasm-objdump (WABT) not found; skipping import check\n"
		return 0
	fi
	BUILD_DIR="$dir" sh "$HERE/check-plugin-imports.sh"
}

lint_all() {
	lint_em_asm
	lint_raw_malloc
	# The build checks are only meaningful once the tree is built; run the
	# symbol check opportunistically so a local `scripts/lint` after a build
	# covers it, but never fail just because nothing is built yet.
	if [ -d build ]; then
		lint_symbols build
	else
		printf "SKIP: ./build not present; skipping symbol check\n"
	fi
}

check="${1:-all}"
[ "$#" -gt 0 ] && shift

case "$check" in
em-asm)     lint_em_asm "$@" ;;
raw-malloc) lint_raw_malloc "$@" ;;
symbols)    lint_symbols "$@" ;;
imports)    lint_imports "$@" ;;
all)        lint_all "$@" ;;
*)
	printf "unknown check '%s'\n" "$check" >&2
	printf "usage: scripts/lint [em-asm|raw-malloc|symbols|imports]\n" >&2
	exit 2
	;;
esac
