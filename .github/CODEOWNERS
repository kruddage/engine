# Code owners — GitHub requests a review from the owner when a matching path
# changes. Order matters: the LAST matching pattern wins for a given file.
# See https://docs.github.com/articles/about-code-owners.

# Default owner for everything not matched more specifically below.
*                       @joshcoyne

# /krudd/ below covers the whole tree — build language, specs, and the engine
# module sources — but the plugin vtable headers ARE the engine ABI (see
# CLAUDE.md), so guard them with their own explicit line: a change to an
# exported signature is a breaking change.
/krudd/engine/abi/      @joshcoyne

# Build and CI/release machinery. krudd renders build.ninja from the directory
# specs (krudd/engine/**/build.scm) and drives ninja directly — no CMake.
/krudd/                 @joshcoyne
/.github/               @joshcoyne

# Version source — maintained by release-please, but guard it so a manual edit
# still routes a review. version.txt is what CI stamps into the build; the
# manifest and config drive release-please itself.
/version.txt                    @joshcoyne
/.release-please-manifest.json  @joshcoyne
/release-please-config.json     @joshcoyne
