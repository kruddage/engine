<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
<title>@PROJECT_NAME@ @PROJECT_VERSION@</title>
<!-- Inline SVG favicon (data URI, no network fetch) so browsers stop
     requesting /favicon.ico and logging a 404 on every load. -->
<link rel="icon" href="data:image/svg+xml,%3Csvg%20xmlns='http://www.w3.org/2000/svg'%20viewBox='0%200%2032%2032'%3E%3Crect%20width='32'%20height='32'%20fill='%230d0d0d'/%3E%3Ctext%20x='16'%20y='23'%20font-family='Courier%20New,monospace'%20font-size='22'%20font-weight='700'%20fill='%23ffffff'%20text-anchor='middle'%3EK%3C/text%3E%3C/svg%3E">
<link rel="manifest" href="manifest.webmanifest">
<link rel="apple-touch-icon" href="icon-192.png">
<meta name="theme-color" content="#0d0d0d">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="KRUDD">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body {
	background: #0d0d0d;
	color: #e0e0e0;
	font-family: 'Courier New', Courier, monospace;
	/*
	 * dvh (dynamic viewport height) tracks the *visible* viewport, so the
	 * app shrinks to fit above a mobile browser's dynamic toolbar instead
	 * of extending behind it — otherwise 100vh (the large viewport) hides
	 * the bottom strip of the canvas, and with it kruddgui's bottom-anchored
	 * panels (the mode-bar, the Log handle), under Firefox Android's URL bar.
	 * The 100vh line is the fallback for browsers without dvh.
	 */
	height: 100vh;
	height: 100dvh;
	display: flex;
	flex-direction: column;
	overflow: hidden;
}

/*
 * ── Editor chrome ──
 *
 * The DOM shell around the wasm canvas. Its whole structure — the menu bar's
 * entries, the toolbar, which docks sit on which edge — is built at runtime by
 * kruddBuildEditor from the layout the engine serializes out of
 * editor_layout.scm (the same spec the native Qt host reads). Nothing below
 * hard-codes a menu item or a dock; the CSS only dresses the containers the
 * builder fills. The canvas viewport is the one fixed element: it is the
 * editor's centre, with docks laid out around it.
 */

.menubar {
	display: flex;
	align-items: center;
	gap: 2px;
	padding: 0 14px 0 20px;
	height: 34px;
	border-bottom: 1px solid #222;
	flex-shrink: 0;
	background: #0d0d0d;
	position: relative;
	z-index: 300;
}

.wordmark {
	font-size: 15px;
	font-weight: bold;
	letter-spacing: 0.2em;
	color: #fff;
	margin-right: 14px;
	user-select: none;
}

.menu {
	position: relative;
}

.menu-title {
	padding: 6px 10px;
	font-size: 12px;
	color: #bbb;
	cursor: pointer;
	user-select: none;
	letter-spacing: 0.03em;
}

.menu.open > .menu-title,
.menu-title:hover {
	background: #1c1c1c;
	color: #fff;
}

.menu-dropdown {
	display: none;
	position: absolute;
	top: 100%;
	left: 0;
	min-width: 210px;
	background: #141414;
	border: 1px solid #333;
	box-shadow: 0 6px 24px rgba(0, 0, 0, 0.7);
	padding: 4px 0;
	z-index: 350;
}

.menu.open > .menu-dropdown { display: block; }

.menu-item {
	display: flex;
	align-items: center;
	justify-content: space-between;
	gap: 28px;
	padding: 5px 14px 5px 28px;
	font-size: 12px;
	color: #ccc;
	cursor: pointer;
	white-space: nowrap;
	position: relative;
}

.menu-item:hover {
	background: #21331f;
	color: #fff;
}

.menu-item .shortcut {
	color: #666;
	font-size: 11px;
	letter-spacing: 0.04em;
}

/* Dock-toggle rows show a check when their dock is visible; the tick sits in
 * the left gutter the extra padding-left reserves. */
.menu-item.checkable::before {
	content: '';
	position: absolute;
	left: 12px;
	color: #4a9a4a;
	font-size: 11px;
}

.menu-item.checkable.checked::before { content: '\2713'; }

.menu-sep {
	height: 1px;
	background: #2a2a2a;
	margin: 4px 0;
}

.menubar-right {
	margin-left: auto;
	display: flex;
	align-items: center;
	gap: 12px;
}

.version {
	font-size: 11px;
	color: #999;
	letter-spacing: 0.1em;
	cursor: pointer;
	user-select: none;
}

.version:hover { color: #ccc; }

.version-detail {
	display: none;
	font-size: 11px;
	color: #777;
	letter-spacing: 0.05em;
}

.version-detail.visible { display: inline; }

.menu-btn {
	background: none;
	border: 1px solid #333;
	color: #888;
	font-family: inherit;
	font-size: 11px;
	letter-spacing: 0.1em;
	padding: 4px 10px;
	cursor: pointer;
}

.menu-btn:hover { border-color: #555; color: #ccc; }

/* ── Toolbar ── */

.toolbar {
	display: flex;
	align-items: center;
	gap: 6px;
	padding: 4px 16px;
	height: 36px;
	border-bottom: 1px solid #222;
	flex-shrink: 0;
	background: #0f0f0f;
	position: relative;
	z-index: 200;
}

.tool-item {
	background: #141414;
	border: 1px solid #333;
	color: #ccc;
	font-family: inherit;
	font-size: 12px;
	letter-spacing: 0.04em;
	padding: 4px 12px;
	cursor: pointer;
}

.tool-item:hover { border-color: #555; color: #fff; }

.tool-sep {
	width: 1px;
	align-self: stretch;
	background: #2a2a2a;
	margin: 3px 5px;
}

.tool-badge {
	font-size: 11px;
	letter-spacing: 0.08em;
	color: #888;
	padding: 3px 9px;
	border: 1px solid #2a2a2a;
	border-radius: 3px;
}

/*
 * Active-renderer badge (the layout's toolbar "renderer" badge on the web
 * host). Starts in the muted "unknown" state and is filled in once the engine
 * backend reports through kruddSetRenderer. WebGPU is the default path now;
 * WebGL is the opt-out (?renderer=webgl, or Firefox). The accent colour makes
 * the active path glanceable: amber for the WebGL shim, green for the WebGPU
 * path. The tooltip also notes whether WebGPU was detected on load (see below).
 */
.renderer {
	display: inline-flex;
	align-items: center;
	gap: 5px;
	font-size: 10px;
	letter-spacing: 0.12em;
	text-transform: uppercase;
	color: #555;
	border: 1px solid #2a2a2a;
	border-radius: 3px;
	padding: 2px 7px;
	user-select: none;
	cursor: pointer;
}

/* Clicking is a no-op when the other backend isn't reachable (see
 * canSwitchTo); the hover tint is still a mild affordance since the title
 * tooltip explains why in that case. */
.renderer:hover { border-color: #444; }

.renderer svg {
	width: 11px;
	height: 11px;
	display: block;
}

.renderer.webgl {
	color: #b98a4a;
	border-color: #4a3a22;
}

.renderer.webgpu {
	color: #4a9a4a;
	border-color: #244a24;
}

/* ── Editor body: docks around the canvas viewport ── */

.editor-body {
	flex: 1;
	display: flex;
	min-height: 0;
}

.dock-col {
	display: flex;
	flex-direction: column;
	flex-shrink: 0;
	width: 250px;
	background: #0d0d0d;
}

.dock-col.left  { border-right: 1px solid #222; }
.dock-col.right { border-left: 1px solid #222; }

.editor-center {
	flex: 1;
	display: flex;
	flex-direction: column;
	min-width: 0;
}

.dock-row {
	flex-shrink: 0;
	display: flex;
	background: #0d0d0d;
}

.dock-row.top    { border-bottom: 1px solid #222; height: 190px; }
.dock-row.bottom { border-top: 1px solid #222; height: 210px; }

/* An empty edge (every dock on it hidden) takes no room. */
.dock-col:empty,
.dock-row:empty { display: none; }

.canvas-wrap {
	flex: 1;
	display: flex;
	align-items: center;
	justify-content: center;
	background: #000;
	min-height: 0;
	min-width: 0;
}

canvas {
	display: block;
	max-width: 100%;
	max-height: 100%;
	width: 100%;
	height: 100%;
}

/* A dock (a tab group of one or more panels) fills its edge. */
.dock {
	display: flex;
	flex-direction: column;
	flex: 1;
	min-height: 0;
	min-width: 0;
}

.dock + .dock { border-top: 1px solid #222; }
.dock-row .dock + .dock { border-top: none; border-left: 1px solid #222; }

.dock.hidden { display: none; }

.dock-tabs {
	display: flex;
	flex-shrink: 0;
	background: #111;
	border-bottom: 1px solid #222;
	overflow-x: auto;
}

.dock-tab {
	padding: 6px 13px;
	font-size: 11px;
	color: #888;
	cursor: pointer;
	border-right: 1px solid #1c1c1c;
	border-top: 2px solid transparent;
	text-transform: uppercase;
	letter-spacing: 0.08em;
	white-space: nowrap;
	user-select: none;
}

.dock-tab:hover { color: #bbb; }

.dock-tab.active {
	color: #fff;
	background: #0d0d0d;
	border-top-color: #4a9a4a;
}

.dock-tab.hidden { display: none; }

.dock-panels {
	flex: 1;
	position: relative;
	overflow: auto;
	min-height: 0;
}

.panel { display: none; padding: 16px 18px; }

.panel.active { display: block; }

.panel .coming-soon {
	font-size: 10px;
	color: #555;
	text-transform: uppercase;
	letter-spacing: 0.14em;
	margin-bottom: 12px;
}

.panel h3 {
	font-size: 13px;
	color: #ddd;
	font-weight: bold;
	letter-spacing: 0.03em;
	margin-bottom: 8px;
}

.panel p {
	font-size: 12px;
	line-height: 1.6;
	color: #888;
	font-family: system-ui, -apple-system, sans-serif;
}

/* ── Status bar ── */

.statusbar {
	display: flex;
	align-items: center;
	gap: 8px;
	padding: 5px 18px;
	height: 26px;
	border-top: 1px solid #222;
	font-size: 11px;
	color: #666;
	flex-shrink: 0;
	background: #0d0d0d;
}

.status-dot {
	width: 6px;
	height: 6px;
	border-radius: 50%;
	background: #2d6a2d;
	animation: pulse 2s ease-in-out infinite;
	flex-shrink: 0;
}

.status-dot.error {
	background: #6a2d2d;
	animation: none;
}

.status-sep {
	width: 1px;
	height: 12px;
	background: #2a2a2a;
	margin: 0 4px;
}

.status-field { color: #888; letter-spacing: 0.04em; }

/* A transient one-line hint (e.g. a "coming soon" menu action), fades on its
 * own; lives on the right of the status bar so it never shoves the fields. */
.status-hint {
	margin-left: auto;
	color: #4a9a4a;
	letter-spacing: 0.04em;
	opacity: 0;
	transition: opacity 0.2s;
}

.status-hint.visible { opacity: 1; }

/*
 * Scrolling diagnostic log for WebGPU bring-up, opt-in behind ?webgpulog=1
 * (see the panel's rationale where it is wired up). A lightweight shell-side
 * panel that carries the backend's step-by-step messages with full history —
 * unlike the single-line status bar. Hidden until the first line arrives.
 */
.webgpu-log {
	position: fixed;
	left: 0;
	right: 0;
	bottom: 30px;
	max-height: 42vh;
	overflow-y: auto;
	background: rgba(0, 0, 0, 0.74);
	border-top: 1px solid #333;
	font-family: 'Courier New', Courier, monospace;
	font-size: 11px;
	line-height: 1.55;
	color: #d0d0d0;
	padding: 8px 14px;
	z-index: 6000;
	display: none;
}

.webgpu-log.visible { display: block; }

.webgpu-log .line { white-space: pre-wrap; }

.webgpu-log .line.err { color: #e07a7a; }

@keyframes pulse {
	0%, 100% { opacity: 1; }
	50%       { opacity: 0.3; }
}

/* ── Launcher overlay ── */

.launcher {
	position: fixed;
	inset: 0;
	background: rgba(13, 13, 13, 0.96);
	display: flex;
	align-items: center;
	justify-content: center;
	z-index: 5000;
	padding: 20px;
}

.launcher.hidden { display: none; }

.launcher-close {
	position: absolute;
	top: 16px;
	right: 20px;
	width: 28px;
	height: 28px;
	background: none;
	border: 1px solid #333;
	color: #888;
	font-family: inherit;
	font-size: 18px;
	line-height: 1;
	cursor: pointer;
}

.launcher-close:hover { border-color: #555; color: #ccc; }

/* Matches .launcher-sub/.launcher-games: no dismissing a launcher that hasn't
 * armed its buttons yet (see kruddSetReady below). */
.launcher.loading .launcher-close { display: none; }

.launcher-panel {
	display: flex;
	flex-direction: column;
	align-items: center;
	gap: 10px;
	width: 100%;
	max-width: 360px;
}

.launcher-title {
	font-size: 32px;
	font-weight: bold;
	letter-spacing: 0.3em;
	color: #fff;
}

.launcher-sub {
	font-size: 12px;
	color: #666;
	letter-spacing: 0.15em;
	text-transform: uppercase;
	margin-bottom: 14px;
}

/*
 * Until the engine has rendered its first frame the launcher is painted (static
 * HTML) but not yet armed: the game list and its prompt are hidden and a
 * "loading" note stands in, so an impatient click has no button to hit. The
 * engine flips the .loading class off via kruddSetReady once it is live.
 */
.launcher-loading {
	display: none;
	font-size: 12px;
	color: #666;
	letter-spacing: 0.15em;
	text-transform: uppercase;
}

.launcher.loading .launcher-loading { display: block; }

.launcher.loading .launcher-sub,
.launcher.loading .launcher-games { display: none; }

.launcher-games {
	display: flex;
	flex-direction: column;
	gap: 10px;
	width: 100%;
}

.launcher-btn {
	background: #141414;
	border: 1px solid #333;
	border-left: 3px solid #2d6a2d;
	color: #ddd;
	font-family: inherit;
	font-size: 15px;
	letter-spacing: 0.08em;
	padding: 14px 18px;
	cursor: pointer;
	text-align: left;
	transition: border-color 0.12s, background 0.12s;
}

.launcher-btn:hover {
	background: #1c1c1c;
	border-color: #555;
	border-left-color: #4a9a4a;
	color: #fff;
}

/* ── Scoreboard overlay ── */

/*
 * A game's HUD, revealed by the tictactoe plugin (games/tictactoe/tictactoe.c)
 * and hidden again on the way back to the menu. It floats just under the
 * toolbar, centred over the canvas; pointer-events:none so a click passes
 * through it to the board beneath.
 */
.scoreboard {
	position: fixed;
	top: 84px;
	left: 50%;
	transform: translateX(-50%);
	display: flex;
	gap: 10px;
	z-index: 400;
	pointer-events: none;
}

.scoreboard.hidden { display: none; }

.score-side {
	display: flex;
	flex-direction: column;
	align-items: center;
	gap: 2px;
	min-width: 74px;
	padding: 8px 16px;
	background: rgba(20, 20, 20, 0.85);
	border: 1px solid #333;
}

/* The accent bar matches each mark: X is the red plastic, O the gold metal. */
.score-x { border-top: 3px solid #c0392b; }
.score-o { border-top: 3px solid #e0a05a; }

.score-label {
	font-size: 11px;
	color: #888;
	letter-spacing: 0.12em;
}

.score-value {
	font-size: 24px;
	font-weight: bold;
	color: #fff;
	line-height: 1;
}

/* ── Error overlay ── */

.error-backdrop {
	position: fixed;
	inset: 0;
	background: rgba(0, 0, 0, 0.75);
	display: none;
	align-items: center;
	justify-content: center;
	z-index: 9999;
	padding: 20px;
}

.error-backdrop.visible {
	display: flex;
}

.error-box {
	background: #111;
	border: 1px solid #5a1a1a;
	border-top: 3px solid #c0392b;
	max-width: 720px;
	width: 100%;
	max-height: 80vh;
	display: flex;
	flex-direction: column;
	box-shadow: 0 8px 40px rgba(0, 0, 0, 0.8);
}

.error-header {
	padding: 12px 16px;
	display: flex;
	align-items: center;
	justify-content: space-between;
	gap: 16px;
	border-bottom: 1px solid #2a1a1a;
	flex-shrink: 0;
}

.error-title-row {
	display: flex;
	align-items: center;
	gap: 8px;
	flex: 1;
	min-width: 0;
	overflow: hidden;
}

.error-icon {
	color: #c0392b;
	font-size: 14px;
	font-weight: bold;
	flex-shrink: 0;
}

.error-label {
	font-size: 13px;
	color: #e74c3c;
	font-weight: bold;
	letter-spacing: 0.05em;
	flex-shrink: 0;
}

.error-source {
	font-size: 11px;
	color: #555;
	padding-right: 4px;
}

.error-actions {
	display: flex;
	align-items: center;
	gap: 8px;
	flex-shrink: 0;
}

.error-dismiss,
.error-copy {
	background: none;
	border: 1px solid #333;
	color: #666;
	font-family: inherit;
	font-size: 11px;
	padding: 3px 10px;
	cursor: pointer;
	letter-spacing: 0.05em;
}

.error-dismiss:hover,
.error-copy:hover {
	border-color: #555;
	color: #aaa;
}

.error-copy.copied {
	border-color: #2d6a2d;
	color: #4a9a4a;
}

.error-body {
	padding: 14px 16px;
	overflow-y: auto;
	font-size: 12px;
	line-height: 1.6;
	color: #ccc;
	flex: 1;
	font-family: system-ui, -apple-system, sans-serif;
}

.error-body h2 {
	font-family: 'Courier New', Courier, monospace;
	color: #e74c3c;
	font-size: 13px;
	margin-bottom: 10px;
	font-weight: bold;
	letter-spacing: 0.03em;
}

.error-body h3 {
	font-family: 'Courier New', Courier, monospace;
	color: #b0b0b0;
	font-size: 12px;
	margin: 10px 0 6px;
	font-weight: bold;
	text-transform: uppercase;
	letter-spacing: 0.08em;
}

.error-body p {
	margin-bottom: 8px;
	color: #bbb;
}

.error-body strong { color: #ddd; font-weight: bold; }

.error-body code {
	font-family: 'Courier New', Courier, monospace;
	background: #1a1a1a;
	border: 1px solid #2a2a2a;
	color: #e0a05a;
	padding: 1px 5px;
	font-size: 11px;
	border-radius: 2px;
}

.error-body pre {
	background: #0a0a0a;
	border: 1px solid #222;
	border-left: 3px solid #5a1a1a;
	padding: 10px 12px;
	margin: 8px 0;
	overflow-x: auto;
	font-size: 11px;
	line-height: 1.5;
}

.error-body pre code {
	background: none;
	border: none;
	padding: 0;
	color: #ccc;
	font-size: 11px;
}

.error-body hr {
	border: none;
	border-top: 1px solid #222;
	margin: 10px 0;
}
</style>
</head>
<body>

<!--
	The editor chrome. The menu bar, toolbar and dock edges are empty
	containers the engine fills at boot (kruddBuildEditor, below) from the
	serialized editor_layout.scm — so the arrangement always matches the native
	Qt shell with no host-specific markup here. Only the canvas viewport and the
	shell chrome that pre-dates the layout (version, menu button, status pill)
	are authored statically.
-->
<div class="menubar" id="menubar">
	<span class="wordmark">KRUDD</span>
	<div class="menubar-right">
		<span class="version" id="version" title="click for build info">@PROJECT_VERSION@</span>
		<span class="version-detail" id="version-detail">commit @GIT_COMMIT_HASH@ &middot; built @BUILD_DATE@</span>
		<button class="menu-btn" id="menu-btn" title="back to the menu">&#9776; menu</button>
	</div>
</div>

<div class="toolbar" id="toolbar"></div>

<div class="editor-body">
	<div class="dock-col left" id="dock-left"></div>
	<div class="editor-center">
		<div class="dock-row top" id="dock-top"></div>
		<div class="canvas-wrap">
			<canvas id="canvas" oncontextmenu="event.preventDefault()"></canvas>
		</div>
		<div class="dock-row bottom" id="dock-bottom"></div>
	</div>
	<div class="dock-col right" id="dock-right"></div>
</div>

<div class="statusbar" id="statusbar">
	<div class="status-dot" id="status-dot"></div>
	<span id="status">loading</span>
	<span class="status-hint" id="status-hint"></span>
</div>

<div class="webgpu-log" id="webgpu-log"></div>

<div class="scoreboard hidden" id="ttt-scoreboard">
	<div class="score-side score-x">
		<span class="score-label">1P &times;</span>
		<span class="score-value" id="ttt-score-x">0</span>
	</div>
	<div class="score-side score-o">
		<span class="score-label">2P &#9711;</span>
		<span class="score-value" id="ttt-score-o">0</span>
	</div>
</div>

<div class="launcher loading" id="launcher">
	<button class="launcher-close" id="launcher-close" title="close menu">&times;</button>
	<div class="launcher-panel">
		<div class="launcher-title">KRUDD</div>
		<div class="launcher-sub">choose a scene</div>
		<div class="launcher-loading" id="launcher-loading">loading&hellip;</div>
		<div class="launcher-games" id="launcher-games"></div>
	</div>
</div>

<div class="error-backdrop" id="error-backdrop">
	<div class="error-box">
		<div class="error-header">
			<div class="error-title-row">
				<span class="error-icon">!</span>
				<span class="error-label" id="error-label"></span>
			</div>
			<div class="error-actions">
				<span class="error-source">index.wasm</span>
				<button class="error-copy" id="error-copy">copy</button>
				<button class="error-dismiss" id="error-dismiss">dismiss</button>
			</div>
		</div>
		<div class="error-body" id="error-body"></div>
	</div>
</div>

<script>
	function renderMarkdown(src) {
		var lines = src.split('\n');
		var out = '';
		var i = 0;

		function esc(s) {
			return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
		}

		function inline(s) {
			s = esc(s);
			s = s.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
			s = s.replace(/`([^`]+)`/g, function(_, c) { return '<code>' + c + '</code>'; });
			return s;
		}

		while (i < lines.length) {
			var line = lines[i];

			if (/^```/.test(line)) {
				var code = [];
				i++;
				while (i < lines.length && !/^```/.test(lines[i]))
					code.push(esc(lines[i++]));
				out += '<pre><code>' + code.join('\n') + '</code></pre>';
				i++;
				continue;
			}
			if (/^## /.test(line))  { out += '<h2>' + inline(line.slice(3)) + '</h2>'; i++; continue; }
			if (/^### /.test(line)) { out += '<h3>' + inline(line.slice(4)) + '</h3>'; i++; continue; }
			if (/^---+$/.test(line.trim())) { out += '<hr>'; i++; continue; }
			if (/^\s*$/.test(line)) { i++; continue; }
			out += '<p>' + inline(line) + '</p>';
			i++;
		}
		return out;
	}

	function errorToMarkdown(detail) {
		var m = detail.match(/^([^\n]+)\n([\s\S]+)$/);
		var message = m ? m[1] : detail;
		var stack   = m ? m[2] : null;
		var md = '## ' + message + '\n\n';
		if (stack)
			md += '### Stack trace\n\n```\n' + stack.trim() + '\n```\n';
		return md;
	}

	document.getElementById('error-dismiss').addEventListener('click', function () {
		document.getElementById('error-backdrop').classList.remove('visible');
	});

	document.getElementById('error-copy').addEventListener('click', function () {
		var btn = this;
		var raw = document.getElementById('error-body').dataset.raw || '';
		navigator.clipboard.writeText(raw).then(function () {
			btn.textContent = 'copied!';
			btn.classList.add('copied');
			setTimeout(function () {
				btn.textContent = 'copy';
				btn.classList.remove('copied');
			}, 2000);
		});
	});

	/* Called by error_overlay.js */
	window.kruddShowError = function (title, detail) {
		document.getElementById('error-label').textContent = title;
		var body = document.getElementById('error-body');
		body.dataset.raw = title + ': ' + detail;
		body.innerHTML = renderMarkdown(errorToMarkdown(detail));
		document.getElementById('error-backdrop').classList.add('visible');
		document.getElementById('status-dot').classList.add('error');
		document.getElementById('status').textContent = 'exception';
	};

	/* Signal that the engine is running (called after Module init) */
	window.kruddSetRunning = function () {
		document.getElementById('status').textContent = 'running';
	};

	/*
	 * Arm the launcher once the first frame is on screen (called from
	 * engine_tick). Dropping the 'loading' class reveals the game buttons;
	 * before this the list is hidden, so a game cannot be picked into an
	 * engine that has not rendered yet.
	 */
	window.kruddSetReady = function () {
		var el = document.getElementById('launcher');
		if (el)
			el.classList.remove('loading');
	};

	/*
	 * Firefox's WebGPU implementation isn't solid enough yet to default to it,
	 * so this forces WebGL there regardless of the ?renderer= query, until
	 * that's revisited. Single source of truth for "should this page run
	 * WebGPU": both the launcher-hiding check below and engine.c's
	 * krudd_wants_webgpu (via window.kruddWantsWebGPU) read it, so the shell
	 * chrome and the actual backend never disagree.
	 */
	function isFirefox() {
		return /firefox/i.test(navigator.userAgent);
	}

	window.kruddWantsWebGPU = function () {
		try {
			if (isFirefox())
				return false;
			return new URLSearchParams(location.search).get('renderer') !== 'webgl';
		} catch (e) {
			return true;
		}
	};

	/*
	 * Which scene the editor opens on boot. The engine reads this once the
	 * subsystems are up (krudd_boot_game in engine.c) and loads the matching
	 * game, so the page lands on a real scene — chess by default — instead of
	 * the "choose a scene" overlay. ?game=<name> picks another registered game
	 * (matched case-insensitively against its launcher label), and ?game=none
	 * (or any unknown name) keeps the launcher up. The menu button still
	 * reopens the launcher to switch scenes after boot.
	 */
	window.kruddBootGame = function () {
		try {
			var g = new URLSearchParams(location.search).get('game');
			return g === null ? 'chess' : g;
		} catch (e) {
			return 'chess';
		}
	};

	/*
	 * The renderer badge. A backend calls kruddSetRenderer from its init with
	 * its own name; the badge shows which GPU path went live — WebGPU by
	 * default, WebGL when ?renderer=webgl opts out (or always, on Firefox).
	 * Separately we probe navigator.gpu on load so the tooltip can say whether
	 * WebGPU was even available; on the WebGL path, a "WebGPU available" note
	 * flags the upgrade. Clicking the badge switches renderers when the other
	 * path is actually reachable (see switchRenderer below).
	 *
	 * The badge element itself is the layout's toolbar "renderer" badge, built
	 * by kruddBuildEditor — so it may not exist yet when the first
	 * kruddSetRenderer arrives on a slow build. g_lastRenderer remembers the
	 * last name so buildToolbar can re-apply it the moment the badge lands.
	 */
	var RENDERER_ICON =
		'<svg viewBox="0 0 16 16" fill="none" stroke="currentColor"' +
		' stroke-width="1.3" stroke-linecap="round">' +
		'<rect x="4" y="4" width="8" height="8" rx="1"/>' +
		'<rect x="6.5" y="6.5" width="3" height="3" rx="0.5"/>' +
		'<path d="M6 4V2M10 4V2M6 14v-2M10 14v-2M4 6H2M4 10H2' +
		'M14 6h-2M14 10h-2"/></svg>';

	var g_lastRenderer = null;

	/* null = not probed yet, true/false once navigator.gpu has answered. */
	window.kruddWebGPUAvailable = null;

	/* Whether clicking the badge could switch TO this renderer right now.
	 * WebGL always works; WebGPU only if this isn't Firefox (locked off above)
	 * and the on-load adapter probe actually found one — offering a switch
	 * that would just reload into the same broken state is worse than not
	 * offering it. */
	function canSwitchTo(name) {
		if (name === 'webgl')
			return true;
		return !isFirefox() && window.kruddWebGPUAvailable === true;
	}

	function refreshRendererTitle() {
		var el = document.getElementById('renderer-badge');
		if (!el)
			return;
		var active = el.dataset.active || '';
		var avail  = window.kruddWebGPUAvailable;
		var t;

		if (active === 'webgpu') {
			t = 'renderer: WebGPU';
			if (canSwitchTo('webgl')) t += ' · click to switch to WebGL';
		} else if (active === 'webgl') {
			t = 'renderer: WebGL';
			if (isFirefox()) {
				t += ' · WebGPU disabled on Firefox for now';
			} else if (avail === true) {
				t += ' · click to switch to WebGPU';
			} else if (avail === false) {
				t += ' · WebGPU unavailable';
			}
		} else {
			t = 'renderer: detecting…';
		}
		el.title = t;
	}

	/* The renderer is picked at boot (krudd_wants_webgpu in engine.c), so
	 * switching means reloading with an updated ?renderer= query rather than
	 * hot-swapping the live backend. WebGPU is the default, so switching to it
	 * just drops the query param instead of writing it out. */
	function switchRenderer(name) {
		var url = new URL(location.href);
		if (name === 'webgpu')
			url.searchParams.delete('renderer');
		else
			url.searchParams.set('renderer', name);
		location.href = url.toString();
	}

	window.kruddSetRenderer = function (name) {
		g_lastRenderer = name;
		var el = document.getElementById('renderer-badge');
		if (!el)
			return;
		var known = name === 'webgl' || name === 'webgpu';
		var label = name === 'webgpu' ? 'WebGPU'
			  : name === 'webgl'  ? 'WebGL'
			  : String(name);
		el.className = known ? 'renderer ' + name : 'renderer';
		el.dataset.active = name;
		el.innerHTML = RENDERER_ICON + '<span>' + label + '</span>';
		refreshRendererTitle();
	};

	/* Attach the click-to-switch behaviour to the renderer badge. Called from
	 * buildToolbar once the badge exists, since it is built from the layout
	 * rather than authored in static HTML. */
	function wireRendererBadge() {
		var el = document.getElementById('renderer-badge');
		if (!el || el.dataset.wired)
			return;
		el.dataset.wired = '1';
		el.addEventListener('click', function () {
			var active = el.dataset.active;
			var target = active === 'webgpu' ? 'webgl' : 'webgpu';
			if (canSwitchTo(target))
				switchRenderer(target);
		});
	}

	/*
	 * Append a line to the WebGPU probe's diagnostic log panel (see the
	 * .webgpu-log note in the stylesheet). Called from the WebGPU backend via
	 * EM_JS at each step; keeps the panel scrolled to the newest entry.
	 *
	 * Opt-in via ?webgpulog=1. WebGPU is the default renderer now, so this
	 * panel was bring-up scaffolding parked on every user's screen. It stays
	 * reachable rather than deleted because it is the only WebGPU diagnostic
	 * that survives on a phone, where there is no console to open — which is
	 * exactly how the dpr != 1 black screen (#610) got reported.
	 */
	window.kruddWebGPULogEnabled =
		new URLSearchParams(location.search).get('webgpulog') === '1';

	window.kruddWebGPULog = function (msg) {
		var box = document.getElementById('webgpu-log');
		if (!box || !window.kruddWebGPULogEnabled)
			return;
		box.classList.add('visible');
		var line = document.createElement('div');
		line.className = 'line' +
			(/fail|no adapter|no instance|no device|error/i.test(msg) ? ' err' : '');
		line.textContent = msg;
		box.appendChild(line);
		box.scrollTop = box.scrollHeight;
	};

	/* Probe WebGPU support once at load; requestAdapter is async, so the
	 * tooltip updates whenever it resolves. Absent navigator.gpu is a plain
	 * "unavailable", not an error. Skipped on Firefox — it's locked to WebGL
	 * regardless of what the adapter probe would say, so probing there would
	 * only make the badge dangle a switch option canSwitchTo would never
	 * offer. */
	(function detectWebGPU() {
		if (isFirefox() || !navigator.gpu ||
		    typeof navigator.gpu.requestAdapter !== 'function') {
			window.kruddWebGPUAvailable = false;
			refreshRendererTitle();
			return;
		}
		navigator.gpu.requestAdapter().then(function (adapter) {
			window.kruddWebGPUAvailable = !!adapter;
		}).catch(function () {
			window.kruddWebGPUAvailable = false;
		}).then(refreshRendererTitle);
	})();

	document.getElementById('version').addEventListener('click', function () {
		document.getElementById('version-detail').classList.toggle('visible');
	});

	/* Reopen the launcher; the engine keeps running behind it, and picking a
	 * game clears the world and builds the chosen scene (game.c). The scoreboard
	 * belongs to the game being left, so hide it — the next tic-tac-toe load
	 * reveals it again, and any other game never wanted it. */
	document.getElementById('menu-btn').addEventListener('click', function () {
		document.getElementById('launcher').classList.remove('hidden');
		var sb = document.getElementById('ttt-scoreboard');
		if (sb) {
			/* Remember whether the scoreboard was up so launcher-close can put it
			 * back if the user backs out without picking a new scene. */
			sb.dataset.wasVisible = sb.classList.contains('hidden') ? '' : '1';
			sb.classList.add('hidden');
		}
	});

	/* Back out of the launcher without picking a scene; the engine (and
	 * whatever scene was already running behind the overlay) keeps going. */
	document.getElementById('launcher-close').addEventListener('click', function () {
		document.getElementById('launcher').classList.add('hidden');
		var sb = document.getElementById('ttt-scoreboard');
		if (sb && sb.dataset.wasVisible)
			sb.classList.remove('hidden');
	});

	if ('serviceWorker' in navigator) {
		window.addEventListener('load', function () {
			navigator.serviceWorker.register('sw.js').catch(function () {});
		});
	}

	/*
	 * ── The DOM editor chrome (#706 part C) ──
	 *
	 * kruddBuildEditor is the Qt-free twin of krudd_qt.cpp's build_editor_chrome:
	 * it walks the layout the engine serializes out of editor_layout.scm and
	 * emits the same menus, toolbar, docks and status fields the native shell
	 * does. Nothing about the arrangement is authored here — a menu item or dock
	 * added to the .scm shows up on this host with no edit below, which is the
	 * whole point of driving both shells from one spec.
	 *
	 * The engine hands us the layout as JSON (script_layout_json → EM_JS
	 * krudd_build_editor) once, early in boot, before any backend reports its
	 * renderer — so the toolbar's renderer badge is in the DOM by the time
	 * kruddSetRenderer fires.
	 *
	 * The serialized shape mirrors the s7 tree one-for-one: every form is an
	 * array whose head is its tag string, e.g.
	 *   ["action", "&Open Project…", "open", "open-project"]
	 *   ["dock", "dock.console", "Console", "bottom", "Scheme REPL", "…",
	 *    ["tabbed-with", "dock.assets"]]
	 * Unknown tags are skipped, never fatal, matching the C readers.
	 */

	/* Qt marks a menu mnemonic with '&' ("&File"); "&&" is a literal ampersand.
	 * The web chrome has no mnemonics, so strip the markers but keep real
	 * ampersands. */
	function stripMnemonic(label) {
		return String(label)
			.replace(/&&/g, '␀')
			.replace(/&/g, '')
			.replace(/␀/g, '&');
	}

	/* A layout node is a tagged array: [tag, ...args]. */
	function tagOf(node)  { return Array.isArray(node) ? node[0] : null; }

	/* The standard-key shortcut symbols the layout uses, shown the way a
	 * browser user expects. 'none' and anything unmapped render blank. */
	var SHORTCUTS = {
		'new': 'Ctrl+N', 'open': 'Ctrl+O', 'save': 'Ctrl+S',
		'save-as': 'Ctrl+Shift+S', 'quit': 'Ctrl+Q',
		'undo': 'Ctrl+Z', 'redo': 'Ctrl+Shift+Z',
		'cut': 'Ctrl+X', 'copy': 'Ctrl+C', 'paste': 'Ctrl+V'
	};

	/* Live dock state, keyed by dock id: whether each dock is shown, and which
	 * dock is the raised tab of each group. Rebuilt on every kruddBuildEditor. */
	var g_dockVisible = {};
	var g_dockActive  = {};   /* group id -> active dock id */
	var g_docks       = [];   /* flat list, declaration order */
	var g_groups      = [];   /* [{id, area, docks:[...], el, tabsEl, panelsEl}] */

	/* A transient status-bar hint — the web stand-in for the native host's
	 * "coming soon" status message on an unwired action. */
	function statusHint(text) {
		var el = document.getElementById('status-hint');
		if (!el)
			return;
		el.textContent = text;
		el.classList.add('visible');
		clearTimeout(el._t);
		el._t = setTimeout(function () { el.classList.remove('visible'); }, 2600);
	}

	/* Close every open menu (click-outside / after an action). */
	function closeMenus() {
		var open = document.querySelectorAll('.menu.open');
		for (var i = 0; i < open.length; i++)
			open[i].classList.remove('open');
	}

	/*
	 * An action's behaviour. reset-layout and the dock toggles are real layout
	 * operations (the View menu's whole job, and in scope for a static default
	 * arrangement); everything else — Open, Save, Play, About… — lands in the
	 * "coming soon" hint, exactly as an unwired id does on the native host, with
	 * functional panels deferred to #676.
	 */
	function runAction(actionId, label) {
		closeMenus();
		if (actionId === 'reset-layout') {
			g_docks.forEach(function (d) { g_dockVisible[d.id] = true; });
			g_groups.forEach(function (grp) {
				g_dockActive[grp.id] = grp.raised || grp.docks[0].id;
			});
			applyDockState();
			statusHint('layout reset');
			return;
		}
		statusHint(stripMnemonic(label) + ': coming soon');
	}

	/* Parse one (dock ...) node into a plain record. */
	function parseDock(node) {
		var d = {
			id: node[1], title: node[2], area: node[3],
			panel: node[4] || '', blurb: node[5] || '',
			tabbedWith: null, raise: false
		};
		for (var i = 6; i < node.length; i++) {
			var ex = node[i];
			if (tagOf(ex) === 'tabbed-with') d.tabbedWith = ex[1];
			else if (tagOf(ex) === 'raise')  d.raise = true;
		}
		return d;
	}

	/* Group docks into tab groups: a dock tabbed-with another joins that dock's
	 * group; every other dock is its own group. Preserves declaration order,
	 * and falls back to a standalone group if a tab target is missing. */
	function groupDocks(docks) {
		var byId = {}, groups = [], index = {};
		docks.forEach(function (d) {
			if (!d.tabbedWith) {
				var g = { id: d.id, area: d.area, docks: [d], raised: null };
				byId[d.id] = g;
				index[d.id] = groups.length;
				groups.push(g);
			}
		});
		docks.forEach(function (d) {
			if (!d.tabbedWith)
				return;
			var host = byId[d.tabbedWith];
			if (host) {
				host.docks.push(d);
			} else {
				var g = { id: d.id, area: d.area, docks: [d], raised: null };
				byId[d.id] = g;
				index[d.id] = groups.length;
				groups.push(g);
			}
		});
		groups.forEach(function (g) {
			g.docks.forEach(function (d) { if (d.raise) g.raised = d.id; });
		});
		return groups;
	}

	function buildMenus(section) {
		var bar = document.getElementById('menubar');
		if (!bar || !Array.isArray(section))
			return;
		/* Drop any menus from a prior build (idempotent rebuild), then insert
		 * the new ones after the wordmark, before the right cluster. */
		var stale = bar.querySelectorAll('.menu');
		for (var s = 0; s < stale.length; s++)
			stale[s].remove();
		var right = bar.querySelector('.menubar-right');

		section.slice(1).forEach(function (menuNode) {
			if (tagOf(menuNode) !== 'menu')
				return;
			var menu = document.createElement('div');
			menu.className = 'menu';

			var title = document.createElement('div');
			title.className = 'menu-title';
			title.textContent = stripMnemonic(menuNode[1]);
			menu.appendChild(title);

			var drop = document.createElement('div');
			drop.className = 'menu-dropdown';
			menu.appendChild(drop);

			menuNode.slice(2).forEach(function (item) {
				appendMenuItem(drop, item);
			});

			/* Click to open/close; while any menu is open, hovering a sibling
			 * switches to it — the familiar menu-bar feel. */
			title.addEventListener('click', function (e) {
				e.stopPropagation();
				var wasOpen = menu.classList.contains('open');
				closeMenus();
				if (!wasOpen)
					menu.classList.add('open');
			});
			title.addEventListener('mouseenter', function () {
				if (document.querySelector('.menu.open')) {
					closeMenus();
					menu.classList.add('open');
				}
			});

			bar.insertBefore(menu, right);
		});
	}

	function appendMenuItem(drop, item) {
		var tag = tagOf(item);
		if (tag === 'separator') {
			var sep = document.createElement('div');
			sep.className = 'menu-sep';
			drop.appendChild(sep);
			return;
		}
		if (tag === 'dock-toggles') {
			/* Expands to one show/hide toggle per dock, in declaration order —
			 * the View menu's body, same as the native host's toggleViewAction. */
			g_docks.forEach(function (d) {
				var row = document.createElement('div');
				row.className = 'menu-item checkable';
				row.dataset.dockId = d.id;
				var name = document.createElement('span');
				name.textContent = d.title;
				row.appendChild(name);
				row.addEventListener('click', function (e) {
					e.stopPropagation();
					g_dockVisible[d.id] = !g_dockVisible[d.id];
					applyDockState();
				});
				drop.appendChild(row);
			});
			return;
		}
		if (tag === 'action') {
			var label = item[1], shortcut = item[2], actionId = item[3];
			var row = document.createElement('div');
			row.className = 'menu-item';
			var name = document.createElement('span');
			name.textContent = stripMnemonic(label);
			row.appendChild(name);
			var keys = SHORTCUTS[shortcut];
			if (keys) {
				var sc = document.createElement('span');
				sc.className = 'shortcut';
				sc.textContent = keys;
				row.appendChild(sc);
			}
			row.addEventListener('click', function (e) {
				e.stopPropagation();
				runAction(actionId, label);
			});
			drop.appendChild(row);
		}
	}

	function buildToolbar(section) {
		var bar = document.getElementById('toolbar');
		if (!bar)
			return;
		bar.innerHTML = '';
		if (!Array.isArray(section))
			return;

		section.slice(1).forEach(function (item) {
			var tag = tagOf(item);
			if (tag === 'separator') {
				var sep = document.createElement('div');
				sep.className = 'tool-sep';
				bar.appendChild(sep);
			} else if (tag === 'item') {
				var btn = document.createElement('button');
				btn.className = 'tool-item';
				btn.textContent = stripMnemonic(item[1]);
				btn.addEventListener('click', function () {
					runAction(item[2], item[1]);
				});
				bar.appendChild(btn);
			} else if (tag === 'badge') {
				var id = item[1], text = item[2];
				var badge = document.createElement('span');
				/* The "renderer" badge is the one the backend updates through
				 * kruddSetRenderer, so it gets the id and class that logic keys
				 * off; other badges are plain host-updatable labels by id. */
				if (id === 'renderer') {
					badge.id = 'renderer-badge';
					badge.className = 'renderer';
				} else {
					badge.id = 'badge-' + id;
					badge.className = 'tool-badge';
				}
				badge.textContent = text;
				bar.appendChild(badge);
			}
		});

		/* The renderer badge now exists: wire its click behaviour and re-apply
		 * any renderer a backend already reported before the badge was built. */
		wireRendererBadge();
		if (g_lastRenderer)
			window.kruddSetRenderer(g_lastRenderer);
		refreshRendererTitle();
	}

	function buildDocks(section) {
		var areas = {
			left:   document.getElementById('dock-left'),
			right:  document.getElementById('dock-right'),
			top:    document.getElementById('dock-top'),
			bottom: document.getElementById('dock-bottom')
		};
		for (var k in areas)
			if (areas[k]) areas[k].innerHTML = '';

		g_docks = [];
		g_groups = [];
		if (!Array.isArray(section))
			return;

		section.slice(1).forEach(function (node) {
			if (tagOf(node) === 'dock')
				g_docks.push(parseDock(node));
		});
		/* Default every dock visible — the same arrangement the native shell
		 * opens with. On a phone the four edges would crush the viewport, so
		 * there the docks start hidden and the canvas gets the whole screen (the
		 * established mobile experience); the View menu still toggles them on.
		 * This is an initial-state choice, not a layout edit: the spec stays the
		 * single source, and both hosts still track it. */
		var narrow = (window.innerWidth || 0) < 860;
		g_docks.forEach(function (d) {
			if (!(d.id in g_dockVisible))
				g_dockVisible[d.id] = !narrow;
		});

		g_groups = groupDocks(g_docks);
		g_groups.forEach(function (grp) {
			var host = areas[grp.area];
			if (!host)
				return;

			var dock = document.createElement('div');
			dock.className = 'dock';

			var tabs = document.createElement('div');
			tabs.className = 'dock-tabs';
			var panels = document.createElement('div');
			panels.className = 'dock-panels';

			grp.docks.forEach(function (d) {
				var tab = document.createElement('div');
				tab.className = 'dock-tab';
				tab.textContent = d.title;
				tab.dataset.dockId = d.id;
				tab.addEventListener('click', function () {
					if (g_dockVisible[d.id]) {
						g_dockActive[grp.id] = d.id;
						applyDockState();
					}
				});
				tabs.appendChild(tab);

				var panel = document.createElement('div');
				panel.className = 'panel';
				panel.dataset.dockId = d.id;
				/* The "coming soon" placeholder — heading (PANEL) and one-line
				 * blurb (BLURB) straight from the layout; real contents are #676. */
				var cs = document.createElement('div');
				cs.className = 'coming-soon';
				cs.textContent = 'coming soon';
				panel.appendChild(cs);
				var h = document.createElement('h3');
				h.textContent = d.panel;
				panel.appendChild(h);
				var p = document.createElement('p');
				p.textContent = d.blurb;
				panel.appendChild(p);
				panels.appendChild(panel);
			});

			dock.appendChild(tabs);
			dock.appendChild(panels);
			host.appendChild(dock);

			grp.el = dock;
			grp.tabsEl = tabs;
			grp.panelsEl = panels;
			if (!(grp.id in g_dockActive))
				g_dockActive[grp.id] = grp.raised || grp.docks[0].id;
		});

		applyDockState();
	}

	/*
	 * Reflect g_dockVisible / g_dockActive into the DOM: hide toggled-off docks,
	 * pick a visible active tab per group, collapse an emptied group, and tick
	 * the matching View-menu toggles. One pass, called after any change so the
	 * menu checks and the docks never drift.
	 */
	function applyDockState() {
		g_groups.forEach(function (grp) {
			var visible = grp.docks.filter(function (d) {
				return g_dockVisible[d.id];
			});
			/* A single-tab group needs no tab strip. */
			grp.tabsEl.style.display = visible.length > 1 ? '' : 'none';
			grp.el.classList.toggle('hidden', visible.length === 0);

			var active = g_dockActive[grp.id];
			if (!active || !g_dockVisible[active])
				active = visible.length ? visible[0].id : null;
			g_dockActive[grp.id] = active;

			grp.docks.forEach(function (d) {
				var tab = grp.tabsEl.querySelector('[data-dock-id="' + d.id + '"]');
				var panel = grp.panelsEl.querySelector('[data-dock-id="' + d.id + '"]');
				var shown = g_dockVisible[d.id];
				if (tab)
					tab.classList.toggle('hidden', !shown),
					tab.classList.toggle('active', d.id === active);
				if (panel)
					panel.classList.toggle('active', shown && d.id === active);
			});
		});

		/* Collapse an edge whose docks are all hidden, so it takes no room —
		 * a dock-col with only display:none docks would still hold its width. */
		['dock-left', 'dock-right', 'dock-top', 'dock-bottom'].forEach(function (aid) {
			var host = document.getElementById(aid);
			if (!host)
				return;
			var live = false;
			g_groups.forEach(function (grp) {
				if (grp.el && grp.el.parentNode === host &&
				    !grp.el.classList.contains('hidden'))
					live = true;
			});
			host.style.display = live ? '' : 'none';
		});

		/* Update the View menu's dock-toggle checkmarks. */
		var rows = document.querySelectorAll('.menu-item.checkable');
		for (var i = 0; i < rows.length; i++) {
			var id = rows[i].dataset.dockId;
			rows[i].classList.toggle('checked', !!g_dockVisible[id]);
		}
	}

	function buildStatusbar(section) {
		var bar = document.getElementById('statusbar');
		if (!bar || !Array.isArray(section))
			return;
		/* Drop any fields from a prior build, keeping the engine-state pill
		 * (status-dot + #status) and the hint that frame it. */
		var old = bar.querySelectorAll('.status-field, .status-sep');
		for (var i = 0; i < old.length; i++)
			old[i].remove();

		var hint = document.getElementById('status-hint');
		section.slice(1).forEach(function (field) {
			if (tagOf(field) !== 'field')
				return;
			var sep = document.createElement('span');
			sep.className = 'status-sep';
			bar.insertBefore(sep, hint);
			var span = document.createElement('span');
			span.className = 'status-field';
			/* id = the field id, so the host can update fps / resolution /
			 * driver by id, the same contract the native status bar uses. */
			span.id = 'status-' + field[1];
			span.textContent = field[2];
			bar.insertBefore(span, hint);
		});
	}

	/* The engine's entry point: build the whole chrome from the layout JSON. */
	window.kruddBuildEditor = function (json) {
		var layout;
		try {
			layout = JSON.parse(json);
		} catch (e) {
			return;
		}
		if (!Array.isArray(layout))
			return;

		var sections = {};
		layout.forEach(function (sec) {
			if (Array.isArray(sec) && typeof sec[0] === 'string')
				sections[sec[0]] = sec;
		});

		/* Docks first: the View menu's dock-toggles expand over them, and the
		 * dock records must exist before buildMenus reads them. */
		buildDocks(sections.docks);
		buildMenus(sections.menus);
		buildToolbar(sections.toolbar);
		buildStatusbar(sections.statusbar);
	};

	/* One document-level listener closes any open menu on an outside click. */
	document.addEventListener('click', closeMenus);
</script>

<script>
var Module = {
	locateFile: function (path, prefix) {
		if (path.endsWith('.wasm'))
			return prefix + path.replace(/\.wasm$/, '.@GIT_COMMIT_HASH@.wasm');
		return prefix + path;
	}
};
</script>

{{{ SCRIPT }}}

</body>
</html>
